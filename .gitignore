# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
frontend/coverage
backend/coverage

# logs (runtime generated)
backend/logs/
**/logs/*.log

# uploads (user-generated content, should not be in repo)
backend/uploads/
**/uploads/**

# cypress
cypress/videos/
cypress/screenshots/
cypress/downloads/
**/cypress/videos/
**/cypress/screenshots/
**/cypress/downloads/

# next.js (build artifacts)
/frontend/.next/
/frontend/out/
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# temporary test scripts (keep test-connection.js as it's in package.json)
**/test-user-route.js
**/test-api-connection.js
**/test-env-vars.js

# env files (can opt-in for committing if needed)
.env*

# Railway/deployment config files (may contain sensitive data)
*railway*.json
*-railway-vars.json
*env-vars*.json
*_ENV_SETUP.md
*DEPLOYMENT*.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
