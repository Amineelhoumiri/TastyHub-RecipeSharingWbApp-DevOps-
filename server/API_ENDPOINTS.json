{
  "baseUrl": "http://localhost:5000",
  "endpoints": [
    {
      "id": 1,
      "name": "Register User",
      "method": "POST",
      "url": "http://localhost:5000/api/users/register",
      "public": true,
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "username": "testuser",
        "email": "test@example.com",
        "password": "password123"
      },
      "description": "Create a new user account"
    },
    {
      "id": 2,
      "name": "Login User",
      "method": "POST",
      "url": "http://localhost:5000/api/users/login",
      "public": true,
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "email": "test@example.com",
        "password": "password123"
      },
      "description": "Log in and get authentication token"
    },
    {
      "id": 3,
      "name": "Get User Profile",
      "method": "GET",
      "url": "http://localhost:5000/api/users/profile",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>"
      },
      "body": null,
      "description": "Get the logged-in user's profile"
    },
    {
      "id": 4,
      "name": "Update User Profile",
      "method": "PUT",
      "url": "http://localhost:5000/api/users/profile",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>",
        "Content-Type": "application/json"
      },
      "body": {
        "username": "newusername",
        "email": "newemail@example.com"
      },
      "description": "Update user profile (username and/or email)"
    },
    {
      "id": 5,
      "name": "Update User Preferences",
      "method": "PUT",
      "url": "http://localhost:5000/api/users/preferences",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>",
        "Content-Type": "application/json"
      },
      "body": {
        "darkMode": true,
        "units": "metric"
      },
      "description": "Update user preferences"
    },
    {
      "id": 6,
      "name": "Get User's Recipes",
      "method": "GET",
      "url": "http://localhost:5000/api/users/recipes",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>"
      },
      "body": null,
      "description": "Get all recipes created by the logged-in user"
    },
    {
      "id": 7,
      "name": "Get User's Favorites",
      "method": "GET",
      "url": "http://localhost:5000/api/users/favorites",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>"
      },
      "body": null,
      "description": "Get all recipes favorited by the logged-in user"
    },
    {
      "id": 8,
      "name": "Get User's Liked Recipes",
      "method": "GET",
      "url": "http://localhost:5000/api/users/liked",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>"
      },
      "body": null,
      "description": "Get all recipes liked by the logged-in user"
    },
    {
      "id": 9,
      "name": "Get All Recipes",
      "method": "GET",
      "url": "http://localhost:5000/api/recipes",
      "public": true,
      "headers": {},
      "body": null,
      "description": "Get all recipes (public endpoint)"
    },
    {
      "id": 10,
      "name": "Get Recipe by ID",
      "method": "GET",
      "url": "http://localhost:5000/api/recipes/:recipeId",
      "public": true,
      "headers": {},
      "body": null,
      "description": "Get a single recipe with all details",
      "example": "http://localhost:5000/api/recipes/010dc286-e0a6-4a9c-985d-2b3ba8134023"
    },
    {
      "id": 11,
      "name": "Create Recipe",
      "method": "POST",
      "url": "http://localhost:5000/api/recipes",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>",
        "Content-Type": "application/json"
      },
      "body": {
        "title": "Chocolate Cake",
        "description": "A delicious chocolate cake recipe",
        "cookingTime": 45,
        "servings": 8,
        "imageUrl": "https://example.com/cake.jpg",
        "ingredients": [
          {
            "name": "Flour",
            "quantity": 2,
            "unit": "cup",
            "notes": "All-purpose"
          },
          {
            "name": "Sugar",
            "quantity": 1.5,
            "unit": "cup"
          }
        ],
        "steps": [
          {
            "stepNumber": 1,
            "instruction": "Preheat oven to 350°F"
          },
          {
            "stepNumber": 2,
            "instruction": "Mix dry ingredients together"
          }
        ]
      },
      "description": "Create a new recipe (title is required, all other fields optional)"
    },
    {
      "id": 12,
      "name": "Update Recipe",
      "method": "PUT",
      "url": "http://localhost:5000/api/recipes/:recipeId",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>",
        "Content-Type": "application/json"
      },
      "body": {
        "title": "Updated Recipe Title",
        "description": "Updated description",
        "cookingTime": 60,
        "servings": 10,
        "imageUrl": "https://example.com/new-image.jpg"
      },
      "description": "Update a recipe (only owner can update)",
      "example": "http://localhost:5000/api/recipes/010dc286-e0a6-4a9c-985d-2b3ba8134023"
    },
    {
      "id": 13,
      "name": "Delete Recipe",
      "method": "DELETE",
      "url": "http://localhost:5000/api/recipes/:recipeId",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>"
      },
      "body": null,
      "description": "Delete a recipe (only owner can delete)",
      "example": "http://localhost:5000/api/recipes/010dc286-e0a6-4a9c-985d-2b3ba8134023"
    },
    {
      "id": 14,
      "name": "Like Recipe",
      "method": "POST",
      "url": "http://localhost:5000/api/recipes/:recipeId/like",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>"
      },
      "body": null,
      "description": "Like or unlike a recipe (toggles like)",
      "example": "http://localhost:5000/api/recipes/010dc286-e0a6-4a9c-985d-2b3ba8134023/like"
    },
    {
      "id": 15,
      "name": "Favorite Recipe",
      "method": "POST",
      "url": "http://localhost:5000/api/recipes/:recipeId/favourite",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>"
      },
      "body": null,
      "description": "Favorite or unfavorite a recipe (toggles favorite)",
      "example": "http://localhost:5000/api/recipes/010dc286-e0a6-4a9c-985d-2b3ba8134023/favourite"
    },
    {
      "id": 16,
      "name": "Create Comment on Recipe",
      "method": "POST",
      "url": "http://localhost:5000/api/recipes/:recipeId/comments",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>",
        "Content-Type": "application/json"
      },
      "body": {
        "comment": "This recipe is amazing!",
        "rating": 5
      },
      "description": "Create a comment/review on a recipe",
      "example": "http://localhost:5000/api/recipes/010dc286-e0a6-4a9c-985d-2b3ba8134023/comments"
    },
    {
      "id": 17,
      "name": "Update Comment",
      "method": "PUT",
      "url": "http://localhost:5000/api/comments/:commentId",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>",
        "Content-Type": "application/json"
      },
      "body": {
        "comment": "Updated comment text",
        "rating": 4
      },
      "description": "Update a comment (only owner can update)",
      "example": "http://localhost:5000/api/comments/0a80fa14-db5e-4f5f-a88f-4ad082af7705"
    },
    {
      "id": 18,
      "name": "Delete Comment",
      "method": "DELETE",
      "url": "http://localhost:5000/api/comments/:commentId",
      "public": false,
      "headers": {
        "Authorization": "Bearer <your_token_here>"
      },
      "body": null,
      "description": "Delete a comment (only owner can delete)",
      "example": "http://localhost:5000/api/comments/0a80fa14-db5e-4f5f-a88f-4ad082af7705"
    }
  ],
  "notes": {
    "authentication": "For protected endpoints, include header: Authorization: Bearer <token_from_login_or_register>",
    "contentType": "All POST/PUT requests need: Content-Type: application/json",
    "ingredientUnits": ["teaspoon", "tablespoon", "cup", "gram", "kilogram", "ml", "liter", "piece", "pinch", "other"],
    "ratingRange": "Rating must be between 1 and 5 (integer)",
    "requiredFields": {
      "register": ["username", "email", "password"],
      "login": ["email", "password"],
      "createRecipe": ["title"],
      "createComment": ["comment"]
    }
  }
}











