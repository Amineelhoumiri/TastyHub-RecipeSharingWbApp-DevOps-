# Database Configuration
DB_NAME=TastyHub
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5500

# JWT Secret (REQUIRED - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters_long

# Server Configuration
PORT=5000
NODE_ENV=development

# URLs (IMPORTANT for deployment!)
# For local development:
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# For production (update these with your deployed URLs):
# FRONTEND_URL=https://your-app.vercel.app
# BACKEND_URL=https://your-backend.railway.app

# Google OAuth (Optional - for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth Callback URL (must match what's in Google Cloud Console)
# For local: http://localhost:5000/api/users/auth/google/callback
# For production: https://your-backend.railway.app/api/users/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:5000/api/users/auth/google/callback

# Sentry Error Tracking (Optional - Production only)
SENTRY_DSN=your_sentry_dsn_here

# Logging
LOG_LEVEL=debug
